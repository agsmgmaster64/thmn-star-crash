
const MULTI_CHECK_SAVINGS = 0
const MULTI_PURCHASE_COINS = 1
const MULTI_ATM_CANCEL = 2

const MULTI_SAVINGS_DEPOSIT = 0
const MULTI_SAVINGS_WITHDRAW = 1

mapscripts CarpetTraining_MapScripts {}

script CarpetTraining_EventScript_NoCoinCasePlay {
	msgbox(CarpetTraining_Text_NoCoinCasePlay)
	releaseall
	end
}

script CarpetTraining_EventScript_CancelGame {
	hidecoinsbox(0, 5)
	closemessage
	releaseall
	end
}

script CarpetTraining_EventScript_CheckWinnings {
	if (var(GAME_CORNER_VAR_WINNINGS) == 0) {
		releaseall
		end
	}
	showcoinsbox(1, 1)
	buffernumberstring(STR_VAR_1, GAME_CORNER_VAR_WINNINGS)
	msgbox(CarpetTraining_Text_WinCoins)
	waitmessage
	addcoins(GAME_CORNER_VAR_WINNINGS)
	setvar(GAME_CORNER_VAR_WINNINGS, 0)
	updatecoinsbox(1, 1)
	playse(SE_SHOP)
	delay(40)
	hidecoinsbox(0, 5)
	closemessage
	releaseall
	end
}

script CarpetTraining_EventScript_Pachinko {
	lockall
	if (!checkitem(ITEM_COIN_CASE)) {
		goto(CarpetTraining_EventScript_NoCoinCasePlay)
	}
	msgbox(CarpetTraining_Text_Pachinko, MSGBOX_YESNO)
	closemessage
	if (var(VAR_RESULT) == NO) {
		goto(CarpetTraining_EventScript_CancelGame)
	}
	playbgm(MUS_ZGS_DARK_BLOW_HOLE, FALSE)
	callnative(PlayPachinko)
    waitstate
	savebgm(MUS_DUMMY)
	fadedefaultbgm
	releaseall
	end
}

 script CarpetTraining_EventScript_PinballSeel {
	lockall
	if (!checkitem(ITEM_COIN_CASE)) {
		goto(CarpetTraining_EventScript_NoCoinCasePlay)
	}
	checkcoins(VAR_TEMP_2)
	if (var(VAR_TEMP_2) < 25) {
		goto(CarpetTraining_EventScript_PinballNotEnough)
	}
	showcoinsbox(1, 1)
	msgbox(CarpetTraining_Text_Pinball, MSGBOX_YESNO)
	closemessage
	if (var(VAR_RESULT) == NO) {
		goto(CarpetTraining_EventScript_CancelGame)
	}
	removecoins(25)
	updatecoinsbox(1, 1)
	playse(SE_SHOP)
	delay(40)
	hidecoinsbox(0, 5)
	playbgm(MUS_CASINO_PLUS_9, FALSE)
	callnative(PlaySeelPinballGame)
    waitstate 
	savebgm(MUS_DUMMY)
	fadedefaultbgm
	goto(CarpetTraining_EventScript_CheckWinnings)
}

script CarpetTraining_EventScript_PinballNotEnough {
	msgbox(CarpetTraining_Text_PinballNotEnough)
	releaseall
	end
}

