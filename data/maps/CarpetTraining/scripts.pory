script CarpetTraining_EventScript_GachaCommon {
	if (!checkitem(ITEM_COIN_CASE)) {
		goto(CarpetTraining_EventScript_NoCoinCasePlay)
	}
	special(StartGacha)
	if (var(VAR_RESULT) == MON_GIVEN_TO_PARTY) {
		msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
		if (var(VAR_RESULT) == YES) {
			call(Common_EventScript_GetGiftMonPartySlot)
			call(Common_EventScript_NameReceivedPartyMon)
		}
		releaseall
		end
	}
	if (var(VAR_RESULT) == MON_GIVEN_TO_PC) {
		msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
		if (var(VAR_RESULT) == YES) {
			call(Common_EventScript_NameReceivedBoxMon)
		}
		call(Common_EventScript_TransferredToPC)
		releaseall
		end
	}
	releaseall
	end
}

script CarpetTraining_EventScript_ATM {
	lockall
    message(CarpetTraining_Text_ATMStart)
    waitmessage
	while {
		dynmultipush(CarpetTraining_Text_ATMCheckSavings, MULTI_CHECK_SAVINGS)
		if (checkitem(ITEM_COIN_CASE)) {
			dynmultipush(CarpetTraining_Text_ATMPurchaseCoins, MULTI_PURCHASE_COINS)
		}
		dynmultipush(CarpetTraining_Text_ATMCancel, MULTI_ATM_CANCEL)
		dynmultistack(0, 0, FALSE, 3, FALSE, MULTI_CHECK_SAVINGS, NULL)
        if (var(VAR_RESULT) > MULTI_PURCHASE_COINS) {
            break
        }
        switch (var(VAR_RESULT)) {
            case MULTI_CHECK_SAVINGS:
				call(CarpetTraining_EventScript_ATMSavings)
            case MULTI_PURCHASE_COINS:
				call(CarpetTraining_EventScript_ATMCoins)
        }
		message(CarpetTraining_Text_ATMLoop)
		waitmessage
	}
	closemessage
	releaseall
	end
}

script CarpetTraining_EventScript_ATMSavings {
	message(CarpetTraining_Text_ATMSavings)
	waitmessage
	showbankbalancebox(0, 0)
	while {
		dynmultipush(CarpetTraining_Text_ATMDeposit, MULTI_SAVINGS_DEPOSIT)
		dynmultipush(CarpetTraining_Text_ATMWithdraw, MULTI_SAVINGS_WITHDRAW)
		dynmultipush(CarpetTraining_Text_ATMCancel, MULTI_ATM_CANCEL)
		dynmultistack(20, 0, FALSE, 3, FALSE, MULTI_SAVINGS_DEPOSIT, NULL)
        if (var(VAR_RESULT) > MULTI_SAVINGS_WITHDRAW) {
            break
        }
		switch (var(VAR_RESULT)) {
			case MULTI_SAVINGS_DEPOSIT:
				hidebankbalancebox
				message(CarpetTraining_Text_ATMTryDeposit)
				waitmessage
				starttransaction(0)
			case MULTI_SAVINGS_WITHDRAW:
				hidebankbalancebox
				message(CarpetTraining_Text_ATMTryWithdraw)
				waitmessage
				starttransaction(1)
		}
		playse(SE_SHOP)
		showbankbalancebox(0, 0)
		waitse
		msgbox(CarpetTraining_Text_ATMSavingsUpdated)
		message(CarpetTraining_Text_ATMSavings)
		waitmessage
	}
	hidebankbalancebox
	return
}

script CarpetTraining_EventScript_ATMCoins {
	message(CarpetTraining_Text_ATMTryPurchaseCoins)
	waitmessage
	showmoneybox(0, 0)
	showcoinsbox(1, 6)
	while {
		multichoicedefault(15, 0, MULTI_GAME_CORNER_COINS, 0, FALSE)
		if (var(VAR_RESULT) > 1) {
			break
		}
		switch(var(VAR_RESULT)) {
			case 0:
				checkcoins(VAR_TEMP_1)
				if (var(VAR_TEMP_1) >= value(9950)) {
					msgbox(CarpetTraining_Text_ATMTooManyCoins)
					break
				}
				if (!checkmoney(1000)) {
					msgbox(CarpetTraining_Text_ATMNotEnoughMoney)
					break
				}
				addcoins(50)
				removemoney(1000)
				updatemoneybox
				updatecoinsbox(1, 6)
				playse(SE_SHOP)
				msgbox(CarpetTraining_Text_ATMGetCoins)
			case 1:
				checkcoins(VAR_TEMP_1)
				if (var(VAR_TEMP_1) >= value(9500)) {
					msgbox(CarpetTraining_Text_ATMTooManyCoins)
					break
				}
				if (!checkmoney(10000)) {
					msgbox(CarpetTraining_Text_ATMNotEnoughMoney)
					break
				}
				addcoins(500)
				removemoney(10000)
				updatemoneybox
				updatecoinsbox(1, 6)
				playse(SE_SHOP)
				msgbox(CarpetTraining_Text_ATMGetCoins)
		}
		message(CarpetTraining_Text_ATMTryPurchaseCoins)
		waitmessage
	}
	closemessage
	hidemoneybox
	hidecoinsbox(0, 5)
	return
}

script CarpetTraining_EventScript_Clerk1 {
	lock
	faceplayer
	message(gText_HowMayIServeYou)
	waitmessage
	coinmart(CarpetTraining_Coinmart_1)
	msgbox(gText_PleaseComeAgain)
	release
	end
}

